{
  "template_id": "python_basic",
  "name": "Python Basic Repo",
  "description": "Template base para un proyecto Python sencillo preparado para desarrollo asistido por agentes.",
  "required_files": [
    ".gitignore",
    "AGENTS.md",
    "README.md",
    "historico_versiones.md",
    "feature_list.json",
    "CHECKPOINTS.md",
    "init.sh",
    "docs/architecture.md",
    "docs/conventions.md",
    "progress/current.md",
    "progress/history.md",
    "progress/decisions.md",
    "progress/blockers.md",
    "src/{{package_name}}/__init__.py",
    "src/{{package_name}}/main.py",
    "tests/test_smoke.py"
  ],
  "required_directories": [
    "docs",
    "progress",
    "src",
    "src/{{package_name}}",
    "tests"
  ],
  "placeholders": [
    "{{project_name}}",
    "{{package_name}}",
    "{{template_id}}"
  ],
  "verification_command": "./init.sh"
}
